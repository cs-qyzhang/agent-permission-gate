# Custom Anthropic-compatible API configuration
# Copy this file to .env and fill in your values.

# API key for the LLM service
PERMISSION_GATE_LLM_API_KEY=your-api-key-here

# Base URL for custom API endpoint (e.g. local vLLM, LiteLLM, etc.)
# Comment out or leave empty to use the default Anthropic API.
PERMISSION_GATE_LLM_BASE_URL=https://api.deepseek.com/anthropic

# Model identifier to use for fallback decisions
PERMISSION_GATE_MODEL=deepseek-v4-flash

PERMISSION_GATE_LOG=~/.claude/claude-code-permission-gate/permission.log
